{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: Debug App",
      "type": "debugpy",
      "request": "launch",
      "python": "${command:python.interpreterPath}",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Django: Debug Tests",
      "type": "debugpy",
      "request": "launch",
      "python": "${command:python.interpreterPath}",
      "module": "pytest",
      "args": ["tests", "-q"],
      "console": "integratedTerminal"
    }
  ]
}
